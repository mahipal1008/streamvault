{
  "name": "streamvault",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "pnpm --parallel --filter=./apps/* dev",
    "build": "pnpm --filter=./packages/* build && pnpm --parallel --filter=./apps/* build",
    "lint": "pnpm --parallel --filter=./apps/* lint",
    "typecheck": "pnpm --parallel --filter=* typecheck"
  },
  "devDependencies": {
    "prettier": "3.4.2",
    "typescript": "5.6.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
